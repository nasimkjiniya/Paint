<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/section_spacing"
    app:cardBackgroundColor="@color/paint_surface_variant"
    app:cardCornerRadius="@dimen/card_radius"
    app:strokeColor="@color/paint_outline"
    app:strokeWidth="@dimen/divider_thickness">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/section_spacing">

        <ImageView
            android:id="@+id/referenceImage"
            android:layout_width="@dimen/reference_artwork_image_size"
            android:layout_height="@dimen/reference_artwork_image_size"
            android:contentDescription="@string/reference_image_content"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/referenceTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/section_spacing"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="@color/paint_text"
            app:layout_constraintEnd_toStartOf="@id/importReferenceButton"
            app:layout_constraintStart_toEndOf="@id/referenceImage"
            app:layout_constraintTop_toTopOf="@id/referenceImage" />

        <TextView
            android:id="@+id/referenceMeta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/section_spacing"
            android:layout_marginTop="@dimen/space_xs"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/paint_outline"
            app:layout_constraintEnd_toStartOf="@id/importReferenceButton"
            app:layout_constraintStart_toEndOf="@id/referenceImage"
            app:layout_constraintTop_toBottomOf="@id/referenceTitle" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/importReferenceButton"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reference_use"
            app:layout_constraintBottom_toBottomOf="@id/referenceImage"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
