<?xml version="1.0" encoding="utf-8"?>
<MotionScene xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <Transition
        app:constraintSetEnd="@id/collapsed"
        app:constraintSetStart="@id/expanded"
        app:duration="@integer/editor_motion_duration" />

    <ConstraintSet android:id="@+id/expanded">
        <Constraint android:id="@id/editorTitle">
            <Layout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toStartOf="@id/toolsToggleButton"
                android:layout_marginEnd="@dimen/space_xs"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </Constraint>

        <Constraint android:id="@id/toolsToggleButton">
            <Layout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toStartOf="@id/overflowButton"
                android:layout_marginEnd="@dimen/space_xs"
                app:layout_constraintTop_toTopOf="parent" />
        </Constraint>

        <Constraint android:id="@id/overflowButton">
            <Layout
                android:layout_width="@dimen/tool_button_size"
                android:layout_height="@dimen/tool_button_size"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </Constraint>

        <Constraint android:id="@id/editorSubtitle">
            <Layout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/editorTitle" />
        </Constraint>

        <Constraint android:id="@id/shapeCountChip">
            <Layout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/editorSubtitle"
                android:layout_marginTop="@dimen/space_xs" />
        </Constraint>

        <Constraint android:id="@id/canvasFrame">
            <Layout
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintBottom_toTopOf="@id/toolCard"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/shapeCountChip" />
        </Constraint>

        <Constraint android:id="@id/toolCard">
            <Layout
                android:layout_width="0dp"
                android:layout_height="@dimen/tool_card_expanded_height"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />
        </Constraint>
    </ConstraintSet>

    <ConstraintSet android:id="@+id/collapsed">
        <Constraint android:id="@id/editorTitle">
            <Layout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toStartOf="@id/toolsToggleButton"
                android:layout_marginEnd="@dimen/space_xs"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </Constraint>

        <Constraint android:id="@id/toolsToggleButton">
            <Layout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toStartOf="@id/overflowButton"
                android:layout_marginEnd="@dimen/space_xs"
                app:layout_constraintTop_toTopOf="parent" />
        </Constraint>

        <Constraint android:id="@id/overflowButton">
            <Layout
                android:layout_width="@dimen/tool_button_size"
                android:layout_height="@dimen/tool_button_size"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </Constraint>

        <Constraint android:id="@id/editorSubtitle">
            <Layout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/editorTitle" />
        </Constraint>

        <Constraint android:id="@id/shapeCountChip">
            <Layout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/editorSubtitle"
                android:layout_marginTop="@dimen/space_xs" />
        </Constraint>

        <Constraint android:id="@id/canvasFrame">
            <Layout
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintBottom_toTopOf="@id/toolCard"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/shapeCountChip" />
        </Constraint>

        <Constraint android:id="@id/toolCard">
            <Layout
                android:layout_width="0dp"
                android:layout_height="@dimen/tool_card_collapsed_height"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />
        </Constraint>
    </ConstraintSet>

</MotionScene>
